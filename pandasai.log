# TODO: import the required dependencies
import pandas as pd

# Use the provided execute_sql_query function to run SQL against the provided table.
# The strategy:
# - Compute average Age by (Pclass, Sex) and average Fare by Pclass (aggregation / groupby)
# - Compute the most common Embarked (mode) to use as a global fill for missing Embarked
# - Left join these aggregates back to the original table and use COALESCE to impute missing values
# - Fill missing Cabin with 'Unknown'
# - Sort the final result by PassengerId
sql_query = """
WITH age_stats AS (
    SELECT Pclass, Sex, AVG(Age) AS avg_age
    FROM table_aec7a6bd6f78cb97d53618ce510b61d8
    WHERE Age IS NOT NULL
    GROUP BY Pclass, Sex
),
fare_stats AS (
    SELECT Pclass, AVG(Fare) AS avg_fare
    FROM table_aec7a6bd6f78cb97d53618ce510b61d8
    WHERE Fare IS NOT NULL
    GROUP BY Pclass
),
most_embarked AS (
    SELECT Embarked
    FROM table_aec7a6bd6f78cb97d53618ce510b61d8
    WHERE Embarked IS NOT NULL
    GROUP BY Embarked
    ORDER BY COUNT(*) DESC
    LIMIT 1
)
SELECT
    t.PassengerId,
    t.Survived,
    t.Pclass,
    t.Name,
    t.Sex,
    -- Impute Age using group-wise average (Pclass & Sex); round to 1 decimal for readability
    COALESCE(t.Age, ROUND(a.avg_age, 1)) AS Age_imputed,
    t.SibSp,
    t.Parch,
    t.Ticket,
    -- Impute Fare using group-wise average (Pclass); keep reasonable precision
    COALESCE(t.Fare, ROUND(f.avg_fare, 4)) AS Fare_imputed,
    -- Replace missing Cabin with 'Unknown'
    COALESCE(t.Cabin, 'Unknown') AS Cabin_imputed,
    -- Impute Embarked with the global most common Embarked
    COALESCE(t.Embarked, me.Embarked) AS Embarked_imputed
FROM table_aec7a6bd6f78cb97d53618ce510b61d8 t
LEFT JOIN age_stats a ON t.Pclass = a.Pclass AND t.Sex = a.Sex
LEFT JOIN fare_stats f ON t.Pclass = f.Pclass
CROSS JOIN most_embarked me
ORDER BY t.PassengerId
"""

# Execute the SQL and retrieve the imputed dataset
imputed_df = execute_sql_query(sql_query)

# Prepare the result variable as a dataframe output
result = { "type": "dataframe", "value": imputed_df }
